# OAuth 2.0 PKCE login
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BOOKMARKS_REDIRECT_URI=http://localhost:8080/callback

# Optional: an already-issued OAuth 2.0 user token pair
X_USER_ACCESS_TOKEN=
X_USER_REFRESH_TOKEN=

# OAuth 1.0a fallback
# Bookmarks require all four values below for direct OAuth 1.0a calls.
X_API_KEY=
X_API_KEY_SECRET=
X_OAUTH1_ACCESS_TOKEN=
X_OAUTH1_ACCESS_TOKEN_SECRET=

# App-only bearer token can be useful for public endpoints,
# but it is not enough for bookmark lookup.
X_BEARER_TOKEN=

# Bookmark monitor webhook target
DISCORD_WEBHOOK_URL=
